# brick-layout v1
blk-w: 24
blk-h: 20
pad-top: 20
pad-bottom: 20
# palette: char = RRGGBB  (. = transparent)
palette:
  . = transparent
  A = d09168
  B = 000000
  C = 151100
# grid: 16×13
grid:
.....|AAAA|AA|.....
.....|AA|AAAA|.....
..|AAAA|AAAA|AAAA|..
.|AAA|AAAA|AAAA|AAA|.
.|AAAA|AAAA|AAAA|AA|.
.|AAA|BBB|AA|BBB|AAA|.
.|AAAA|AAAA|AAAA|AA|.
.|AAA|AAAA|AAAA|AAA|.
.|AAA|CC|CCCC|CC|AAA|.
.|AAAA|CCCC|CC|AAAA|.
.|AAAA|A|CCCC|AAAA|A|.
..|AAAA|AAAA|AAA|A|..
....|AAA|AAAA|A|....
